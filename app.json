{
  "expo": {
    "name": "QuranNotes",
    "slug": "QuranNotes-app",
    "version": "2.2.1",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#FAF5FF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mahmoudahmedalaa.qurannotes",
      "appleTeamId": "2S42RLH67Y",
      "buildNumber": "42",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow QuranNotes to use the microphone for voice follow-along recitation",
        "NSSpeechRecognitionUsageDescription": "Allow QuranNotes to use speech recognition for voice follow-along",
        "NSPhotoLibraryUsageDescription": "Allow QuranNotes to access your photo library to select a profile picture",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "audio"
        ]
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.mahmoudahmedalaa.qurannotes"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.mahmoudahmedalaa.qurannotes",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Allow QuranNotes to use the microphone for voice recordings"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ],
      "@react-native-google-signin/google-signin",
      "@react-native-community/datetimepicker",
      [
        "@jamsch/expo-speech-recognition",
        {
          "microphonePermission": "Allow QuranNotes to use the microphone for voice follow-along recitation",
          "speechRecognitionPermission": "Allow QuranNotes to use speech recognition for voice follow-along"
        }
      ],
      "@bacons/apple-targets",
      "./plugins/widget-infoplist-fix"
    ],
    "scheme": [
      "qurannotes",
      "com.googleusercontent.apps.825913576002-cj4sli54hrmo1om3g34vo54mvc03oavk"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2763d9a0-0946-44c2-9f8c-2671fafba27a"
      }
    }
  }
}